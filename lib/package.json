{
  "name": "xeerpe",
  "version": "0.0.3",
  "private": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/*",
    "media",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && rspack build && tsc --emitDeclarationOnly --outDir dist"
  },
  "devDependencies": {
    "@rspack/cli": "latest",
    "@rspack/core": "latest",
    "typescript": "^5"
  }
}