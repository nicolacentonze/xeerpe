{
  "name": "xerpe-workspace",
  "private": true,
  "workspaces": ["lib", "doc"],
  "scripts": {
    "dev": "npm run dev --workspace=doc",
    "build:lib": "npm run build --workspace=lib",
    "build:doc": "npm run build --workspace=doc",
    "publish:lib": "npm run build:lib && npm publish --workspace=lib"
  }
}